commodity_zone_wide <- commodity_zone_prop %>%
select(host_type, zone, proportion) %>%
pivot_wider(names_from = zone, values_from = proportion, values_fill = 0)
if (!"High EI (>60)" %in% names(commodity_zone_wide)) {
commodity_zone_wide[["High EI (>60)"]] <- 0
}
if (!"GI-only (seasonal risk)" %in% names(commodity_zone_wide)) {
commodity_zone_wide[["GI-only (seasonal risk)"]] <- 0
}
commodity_risk_summary <- commodity_zone_wide %>%
mutate(dominant_risk = case_when(
`High EI (>60)` >= `GI-only (seasonal risk)` ~ "Establishment risk (High EI)",
TRUE ~ "Seasonal incursion risk (GI-only)"
)) %>%
arrange(desc(`High EI (>60)`))
commodity_risk_summary
# Combine: 1 = low, 2 = moderate, 3 = high, 4 = GI-only
zone_rast <- ifel(!is.na(ei_zone) & ei_zone > 0, ei_zone, gi_only)
zone_labels <- c("1" = "Low EI (1-20)", "2" = "Moderate EI (20-60)",
"3" = "High EI (>60)", "4" = "GI-only (seasonal risk)")
host_zone_tab <- crosstab(c(hosts_ei_aligned, zone_rast), long = TRUE)
names(host_zone_tab) <- c("host_type", "zone_code", "n_cells")   # Value IS the commodity name
host_zone_tab$zone <- zone_labels[as.character(host_zone_tab$zone_code)]
unique(host_zone_tab$zone)   # sanity check — should show your 4 zone names now
overall_prop <- host_zone_tab %>%
group_by(zone) %>%
summarise(n_cells = sum(n_cells)) %>%
mutate(proportion = n_cells / sum(n_cells))
overall_prop
commodity_zone_prop <- host_zone_tab %>%
group_by(host_type, zone) %>%
summarise(n_cells = sum(n_cells), .groups = "drop") %>%
group_by(host_type) %>%
mutate(proportion = n_cells / sum(n_cells)) %>%
arrange(host_type, zone)
commodity_zone_prop
ei_zone <- classify(aus_ei,
rcl = matrix(c(
0,   1, 0,   # non-establishing — assessed against GI below
1,  5, 1,   # low
5, 10, 2,   # moderate
10, 100, 3   # high
), ncol = 3, byrow = TRUE),
include.lowest = TRUE, right = TRUE)
gi_only <- ifel(aus_gi > 0 & (is.na(aus_ei) | aus_ei == 0), 4, NA)
zone_rast <- ifel(!is.na(ei_zone) & ei_zone > 0, ei_zone, gi_only)
zone_labels <- c("1" = "Low EI (1-20)", "2" = "Moderate EI (20-60)",
"3" = "High EI (>60)", "4" = "GI-only (seasonal risk)")
host_zone_tab <- crosstab(c(hosts_ei_aligned, zone_rast), long = TRUE)
names(host_zone_tab) <- c("host_type", "zone_code", "n_cells")   # Value IS the commodity name
host_zone_tab$zone <- zone_labels[as.character(host_zone_tab$zone_code)]
overall_prop <- host_zone_tab %>%
group_by(zone) %>%
summarise(n_cells = sum(n_cells)) %>%
mutate(proportion = n_cells / sum(n_cells))
overall_prop
commodity_zone_prop <- host_zone_tab %>%
group_by(host_type, zone) %>%
summarise(n_cells = sum(n_cells), .groups = "drop") %>%
group_by(host_type) %>%
mutate(proportion = n_cells / sum(n_cells)) %>%
arrange(host_type, zone)
commodity_zone_prop
ei_zone <- classify(aus_ei,
rcl = matrix(c(
0,   1, 0,   # non-establishing — assessed against GI below
1,  5, 1,   # low
5, 10, 2,   # moderate
10, 100, 3   # high
), ncol = 3, byrow = TRUE),
include.lowest = TRUE, right = TRUE)
gi_only <- ifel(aus_gi > 0 & (is.na(aus_ei) | aus_ei == 0), 4, NA)
zone_rast <- ifel(!is.na(ei_zone) & ei_zone > 0, ei_zone, ifel(!is.na(gi_only), gi_only, 5))   # 5 = outside EI & GI
zone_labels <- c(
"1" = "Low EI (-)",
"2" = "Moderate EI (-)",
"3" = "High EI (>)",
"4" = "GI-only (seasonal risk)",
"5" = "Outside EI & GI (no data)")
host_zone_tab <- crosstab(c(hosts_ei_aligned, zone_rast), long = TRUE)
names(host_zone_tab) <- c("host_type", "zone_code", "n_cells")   # Value IS the commodity name
host_zone_tab$zone <- zone_labels[as.character(host_zone_tab$zone_code)]
overall_prop <- host_zone_tab %>%
group_by(zone) %>%
summarise(n_cells = sum(n_cells)) %>%
mutate(proportion = n_cells / sum(n_cells))
overall_prop
commodity_zone_prop <- host_zone_tab %>%
group_by(host_type, zone) %>%
summarise(n_cells = sum(n_cells), .groups = "drop") %>%
group_by(host_type) %>%
mutate(proportion = n_cells / sum(n_cells)) %>%
arrange(host_type, zone)
commodity_zone_prop
