category_labels <- c(
  "3.4.0 Perennial horticulture" = "Perennial horticulture",
  "3.4.1 Tree fruits" = "Tree fruits",
  "3.4.5 Shrub berries and fruits" = "Shrub berries and fruits",
  "3.4.8 Citrus" = "Citrus",
  "3.4.9 Grapes" = "Grapes",
  "5.1.0 Intensive horticulture" = "Intensive horticulture",
  "5.1.2 Shadehouses" = "Shadehouses",
  "5.1.3 Glasshouses" = "Glasshouses")

# Write the final map to file
tiff("D.suzukii_hosts_aus.tiff", units="in", width=8, height=4, res=500)
par(oma=c(0, 0, 0, 1))
par(mar=c(0, 0, 0, 1))

plot(abares_modal_albers, axes = FALSE, plg = FALSE, legend = FALSE,
     main = expression('Australian host distribution for '*italic(Drosophila~suzukii)*''))

lines(aus_boundary_albers, col = "black", lwd = 1)
lines(aus_states_albers,   col = "black", lwd = 1)

par(xpd = NA)
legend("right", inset = c(-0.05, 0),
       legend = category_labels[categories_to_keep],
       fill = base_cols[categories_to_keep],
       bty = "n", cex = 0.9)
invisible(dev.off())
```

```{r}
# Export the aggregated categorical raster as a GeoTIFF.
#
# NOTE: this writes abares_modal (WGS84, no colour table attached) rather
# than abares_modal_albers (the projected version with the colour table used
# for the plot above). If downstream users need the same projection/colours
# as the figure, consider writing abares_modal_albers instead or as well,
# and/or sending output to a shared directory (e.g. "../outputs/") rather
# than the working directory for consistency with how inputs are read from
# "../data/".
writeRaster(abares_modal, filename = "abares_modal_hosts.tif",
  filetype = "GTiff", overwrite = TRUE)
```
