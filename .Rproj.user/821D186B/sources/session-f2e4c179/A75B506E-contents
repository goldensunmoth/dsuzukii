### Data files

- Download and read in the most recent 2020-21 ABARES NLUM dataset from <https://www.agriculture.gov.au/abares/aclump/land-use/land-use-of-australia-2010-11-to-2020-21#downloads>

```{r data}
# Attribute table: maps integer raster codes to land-use category labels
abares_csv <- read.csv("../data/NLUM_v7_250_INPUTS_2020_21_geo.csv")

# Native-resolution (250 m) categorical land-use raster for Australia
abares_tif <- rast("../data/NLUM_v7_250_INPUTS_2020_21_geo.tif")
```

### Define and apply Australian Albers Equal Area projection
```{r}
# Albers Equal Area is used for the final plot/output so that cell/area
# comparisons across the continent aren't distorted by a geographic CRS
aus_albers <- "+proj=aea +lat_0=0 +lon_0=132 +lat_1=-18 +lat_2=-36 +x_0=0 +y_0=0 +ellps=GRS80 +towgs84=0,0,0,0,0,0,0 +units=m +no_defs"

aus_boundary <- vect(aus_boundary)
aus_boundary_albers <- project(aus_boundary, aus_albers)

aus_states <- ozmap_states
aus_states <- vect(aus_states)
aus_states_albers <- project(aus_states, aus_albers)
```

### Subset ABARES categories to relevant land use types
- Merge irrigated and non-irrigated categories
- Identify categories to retain
```{r setcategories}
# Collapse the four irrigated horticulture codes into their non-irrigated
# equivalents, since the analysis doesn't need to distinguish irrigation
# status - only whether the land use is a relevant commodity host category.
#
# CHECK: this list covers tree fruits / citrus / grapes / shrub berries only.
# Confirm against the ABARES 2020-21 data dictionary whether an irrigated
# equivalent exists for "3.4.0 Perennial horticulture" itself, or for the
# 5.1.x intensive horticulture codes - if so and it's not merged here, those
# pixels will silently be excluded from categories_to_keep below.
abares_csv_merged <- abares_csv %>%
  mutate(TERTV8_merged = case_when(
    TERTV8 == "4.4.1 Irrigated tree fruits" ~ "3.4.1 Tree fruits",
    TERTV8 == "4.4.8 Irrigated citrus" ~ "3.4.8 Citrus",
    TERTV8 == "4.4.9 Irrigated grapes" ~ "3.4.9 Grapes",
    TERTV8 == "4.4.5 Irrigated shrub berries and fruits" ~ "3.4.5 Shrub berries and fruits",
    TRUE ~ TERTV8 ))

# Apply the merged attribute table to the raster and make it the active
# category, so raster values now resolve to TERTV8_merged labels
levels(abares_tif) <- abares_csv_merged
activeCat(abares_tif) <- "TERTV8_merged"

# The commodity-host land-use classes we want to keep for the final map
categories_to_keep <- c("3.4.0 Perennial horticulture",
                        "3.4.1 Tree fruits",
                        "3.4.5 Shrub berries and fruits",
                        "3.4.8 Citrus",
                        "3.4.9 Grapes",
                        "5.1.0 Intensive horticulture",
                        "5.1.2 Shadehouses",
                        "5.1.3 Glasshouses")
```


```{r}
# Look up the integer raster codes ("Value") corresponding to the
# categories_to_keep labels, via the merged attribute table
level_table <- levels(abares_tif)[[1]]
values_to_keep <- level_table$Value[level_table$TERTV8_merged %in% categories_to_keep]

# Keep only pixels in categories_to_keep; everything else becomes NA.
#
# STREAMLINING NOTE: this mask+classify combo can be done in one step, e.g.:
#   abares_filtered <- classify(abares_tif, cbind(values_to_keep, values_to_keep), others = NA)
# which maps kept values to themselves and everything else to NA directly,
# without needing the intermediate 1/NA mask_raster. Left as two steps here
# since that's how it was written, but worth simplifying.
mask_raster <- classify(abares_tif, cbind(values_to_keep, 1), others = NA)
abares_filtered <- mask(abares_tif, mask_raster)

# mask() can drop the categorical attribute table, so it's reapplied here
levels(abares_filtered) <- abares_csv_merged
activeCat(abares_filtered) <- "TERTV8_merged"

# --- Define 10 arc-minute target raster in WGS84 ---
# This is the destination grid we'll eventually snap the aggregated data to,
# cropped to roughly the Australian mainland + Tasmania bounding box
target_res <- rast()
res(target_res) <- 10/60
ext(target_res) <- ext(113, 154, -44, -10)

# --- Project to WGS84 first ---
# method = "near" (nearest neighbour) is required for categorical data -
# any interpolating method would invent nonsense intermediate category codes
abares_wgs84 <- project(abares_filtered, "EPSG:4326", method = "near")

# --- Aggregate to ~10 arc-min using modal, then snap to target grid ---
# Work out how many native pixels need to be combined into one 10 arc-min
# cell (native resolution here is close to, but not exactly, a clean
# divisor of 10 arc-min, hence the round() and the later resample-to-grid
# step to fix up any residual misalignment)
agg_factor <- round((10/60) / res(abares_wgs84)[1])

# Aggregate: 
# See NOTE at the top of this document re: modal vs. mean/proportion + floor.
abares_agg <- aggregate(abares_wgs84, fact = agg_factor, fun = "modal", na.rm = TRUE)

# Resample (nearest neighbour, so category codes are preserved) onto the
# exact target_res grid defined above, correcting any small offset left
# over from the aggregation step
abares_modal <- resample(abares_agg, target_res, method = "near")

# Re-attach the category labels (aggregate/resample can drop them)
levels(abares_modal) <- abares_csv_merged
activeCat(abares_modal) <- "TERTV8_merged"

# Reproject the aggregated categorical raster to Albers for area-correct
# continental plotting
abares_modal_albers <- project(abares_modal, aus_albers, method = "near")
levels(abares_modal_albers) <- abares_csv_merged # restore full category table
activeCat(abares_modal_albers) <- "TERTV8_merged"

# --- Build the colour table for plotting ---
lu_table <- levels(abares_modal_albers)[[1]]

# Default everything to grey (covers any category not in categories_to_keep,
# which shouldn't appear post-filtering, but keeps the table complete/safe)
cols <- rep("#d9d9d9", nrow(lu_table))

base_cols <- c(
  "3.4.0 Perennial horticulture" = "#f27e05",
  "3.4.1 Tree fruits" = "#6bbc44",
  "3.4.5 Shrub berries and fruits" = "#d10065",
  "3.4.8 Citrus" = "#ffd932",
  "3.4.9 Grapes" = "#8838c3",
  "5.1.0 Intensive horticulture" = "#445426",
  "5.1.2 Shadehouses" = "#0057c2",
  "5.1.3 Glasshouses" = "#00aeef" )
names(base_cols) <- categories_to_keep

idx <- match(lu_table$TERTV8_merged, categories_to_keep)
cols[!is.na(idx)] <- base_cols[idx[!is.na(idx)]]

coltab(abares_modal_albers) <- data.frame(
  value = lu_table$Value,
  col = cols)
```

