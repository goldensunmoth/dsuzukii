fill = ei_cols, title = "Ecoclimatic Index", bty = "n", cex = 0.6, horiz = FALSE)
legend("center",
legend = paste(gi_breaks[-length(gi_breaks)], gi_breaks[-1], sep = " – "),
fill = gi_cols, title = "Growth Index", bty = "n", cex = 0.6, horiz = FALSE)
legend("right", inset = c(0.32, 0),
legend = c("Records", "GI >0 and Generations <1"),
pch = c(1, 15),
col = c("darkblue", "lightpink"),
pt.cex = c(0.8, 1.5),
bty = "n", cex = 0.6, horiz = FALSE)
dev.off()
# Define Australian Albers Equal Area projection
aus_albers <- "+proj=aea +lat_0=0 +lon_0=132 +lat_1=-18 +lat_2=-36 +x_0=0 +y_0=0 +ellps=GRS80 +towgs84=0,0,0,0,0,0,0 +units=m +no_defs"
# Reproject composite rasters to Australian Albers
comp_ei_albers <- project(comp_ei, aus_albers, method="near")
comp_gi_albers <- project(comp_gi, aus_albers, method="near")
# Reproject Australia boundary to Australian Albers
aus_boundary <- ne_countries(country = "Australia",
scale = "medium",
returnclass = "sf")
aus_boundary <- vect(aus_boundary)
aus_boundary_albers <- project(aus_boundary, aus_albers)
aus_ei <- crop(comp_ei_albers, aus_boundary_albers) # reduces the extent to just the bounding box of Australia
aus_ei <- mask(aus_ei, aus_boundary_albers) # NA values outside the Australia polygon
aus_gi <- crop(comp_gi_albers, aus_boundary_albers)
aus_gi <- mask(aus_gi, aus_boundary_albers)
hosts <- rast("abares_modal_hosts.tif")
# Reproject hosts to Australian Albers to match
hosts_albers <- project(hosts, aus_albers, method="near")
hosts_bin <- !is.na(hosts_albers)
hosts_bin <- mask(hosts_bin, aus_boundary_albers)
hosts_bin[hosts_bin == 0] <- NA
cross.host <- as.polygons(hosts_bin, dissolve = FALSE)
tiff("D.suzukii_CM10_comp_EIGIhosts_aus.tiff", units="in", width=8, height=4, res=600)
par(oma=c(0, 0, 0, 1))
par(mar=c(0, 0, 0, 1))
plot(aus_gi, col=gi_cols, breaks=gi_breaks, axes=FALSE,
main=expression("Australian climate suitability and hosts for "*italic(Drosophila~suzukii)*""),
xlim=c(-2500000, 2500000), ylim=c(-5000000, -1000000),
legend=FALSE)
plot(aus_ei, col=ei_cols, breaks=ei_breaks, add=TRUE, legend=FALSE)
plot(cross.host, density = 60, angle = 45, add=TRUE, border = NA, col = adjustcolor("grey20"))
lines(aus_boundary_albers, col="black", lwd=1)  # Use aus_boundary_albers here!
legend("topright",
inset=c(0.1, 0.05), legend = paste(ei_breaks[-length(ei_breaks)], ei_breaks[-1], sep = " – "),
fill=ei_cols, title="Ecoclimatic Index", bty="n", cex=0.8, xpd=TRUE)
legend("topright",
inset=c(-0.05, 0.05), legend=paste(gi_breaks[-length(gi_breaks)], gi_breaks[-1], sep = " – "),
fill=gi_cols, title="Growth Index", bty="n", cex=0.8, xpd=TRUE)
legend("topright",
inset=c(0, 0.4), legend=c("Commercial Hosts"), density = 60, angle = 45,
fill = adjustcolor("grey20"), border=NA, title = "Host Presence", bty = "n", cex=0.8, xpd=TRUE)
dev.off()
# Define European ETRS89 LAEA projection
euro_ETRS89 <- "+proj=laea +lat_0=52 +lon_0=10 +x_0=4321000 +y_0=3210000 +ellps=GRS80 +towgs84=0,0,0,0,0,0,0 +units=m +no_defs"
# Reproject composite rasters to European ETRS89
comp_ei_euro <- project(comp_ei, euro_ETRS89, method="near")
comp_gi_euro <- project(comp_gi, euro_ETRS89, method="near")
# Reproject Europe boundary to European ETRS89
euro_boundary <- ne_countries(continent = "Europe",
scale = "medium",
returnclass = "sf")
euro_boundary <- vect(euro_boundary)
euro_boundary_ETRS89 <- project(euro_boundary, euro_ETRS89)
# Define extent for Western/Central Europe (excluding eastern Russia)
euro_extent <- ext(2500000, 7000000, 1300000, 5500000)  # xmin, xmax, ymin, ymax in ETRS89 meters
euro_ei <- crop(comp_ei_euro, euro_boundary_ETRS89) # reduces the extent to just the bounding box of Europe
euro_ei <- mask(euro_ei, euro_boundary_ETRS89) # NA values outside the Europe polygon
euro_gi <- crop(comp_gi_euro, euro_boundary_ETRS89)
euro_gi <- mask(euro_gi, euro_boundary_ETRS89)
records_euro <- project(records, euro_ETRS89)
records_euro <- mask(records_euro, euro_boundary_ETRS89)
no_generations_euro <- project(no_generations, euro_ETRS89, method="near")
no_generations_euro <- mask(no_generations_euro, euro_boundary_ETRS89)
# 16. Define North America Albers Equal Area Conic projection
nad83_albers <- "+proj=aea +lat_0=40 +lon_0=-96 +lat_1=20 +lat_2=60 +x_0=0 +y_0=0 +datum=NAD83 +units=m +no_defs"
# Reproject composite rasters to NAD83 Albers
comp_ei_nad <- project(comp_ei, nad83_albers, method="near")
comp_gi_nad <- project(comp_gi, nad83_albers, method="near")
# Get North America boundary
nam_boundary <- ne_countries(continent = "North America",
scale = "medium",
returnclass = "sf")
nam_boundary <- vect(nam_boundary)
nam_boundary_nad <- project(nam_boundary, nad83_albers)
# 17. Clip EI and GI rasters to North America boundary file
nad_ei <- crop(comp_ei_nad, nam_boundary_nad)
nad_ei <- mask(nad_ei, nam_boundary_nad)
nad_gi <- crop(comp_gi_nad, nam_boundary_nad)
nad_gi <- mask(nad_gi, nam_boundary_nad)
records_nad <- project(records, nad83_albers)
records_nad <- mask(records_nad, nam_boundary_nad)
no_generations_nad <- project(no_generations, nad83_albers, method="near")
no_generations_nad <- mask(no_generations_nad, nam_boundary_nad)
tiff("nam_euro.tiff", units="in", width=10, height=5, res=500)
# Set up the layout: 2 plots on top, 1 legend area below
layout(matrix(c(1, 2, 3, 3), nrow = 2, byrow = TRUE),
heights = c(0.80, 0.20))
par(mar = c(0, 2, 2, 1))
plot(nad_gi, col = gi_cols, breaks = gi_breaks,
main = expression('A. North American composite climate suitability for '*italic(Drosophila~suzukii)),
legend = FALSE, axes = FALSE, , cex.main = 0.8)
plot(no_generations_nad, col = c("lightpink"), add = TRUE, legend = FALSE)
plot(nad_ei, col = ei_cols, breaks = ei_breaks, add = TRUE, legend = FALSE)
plot(records_nad, col = "darkblue", cex = 0.2, lwd = 0.1, alpha = 0.7, pch = 1, legend = FALSE, add = TRUE)
plot(nam_boundary_nad, add = TRUE, border = "black", lwd = 0.4)
par(mar = c(0, 1, 2, 2))
plot(euro_gi, col = gi_cols, breaks = gi_breaks,
main = expression('B. European composite climate suitability for '*italic(Drosophila~suzukii)),
xlim = c(2500000, 6500000), ylim = c(1300000, 5500000),
legend = FALSE, axes = FALSE, , cex.main = 0.8)
plot(no_generations_euro, col = c("lightpink"), add = TRUE, legend = FALSE)
plot(euro_ei, col = ei_cols, breaks = ei_breaks, add = TRUE, legend = FALSE)
plot(records_euro, col = "darkblue", cex = 0.2, lwd = 0.1, alpha = 0.7, pch = 1, legend = FALSE, add = TRUE)
plot(euro_boundary_ETRS89, add = TRUE, border = "black", lwd = 0.4)
# Plot 3: Shared legend (bottom, spanning both plots)
par(mar = c(1, 1, 0, 1))
plot(1, type = "n", axes = FALSE, xlab = "", ylab = "")
legend("left", inset = c(0.2, 0),
legend = paste(ei_breaks[-length(ei_breaks)], ei_breaks[-1], sep = " – "),
fill = ei_cols, title = "Ecoclimatic Index", bty = "n", cex = 0.8, horiz = FALSE)
legend("center",
legend = paste(gi_breaks[-length(gi_breaks)], gi_breaks[-1], sep = " – "),
fill = gi_cols, title = "Growth Index", bty = "n", cex = 0.8, horiz = FALSE)
legend("right", inset = c(0.15, 0),
legend = c("Records", "GI >0 and Generations <1"),
pch = c(1, 15),
col = c("darkblue", "lightpink"),
pt.cex = c(0.8, 1.5),
bty = "n", cex = 0.8, horiz = FALSE)
dev.off()
